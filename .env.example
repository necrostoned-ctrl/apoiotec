# ============================================
# APOIOTEC INFORMÁTICA - CONFIGURAÇÃO
# ============================================
# Copie este arquivo para .env e preencha com suas informações
# NUNCA compartilhe o arquivo .env - ele contém informações sensíveis!

# ============================================
# APLICAÇÃO
# ============================================

# Ambiente (development ou production)
NODE_ENV=production

# Porta onde o servidor vai rodar
PORT=5000

# Host (0.0.0.0 permite acesso de qualquer IP na rede, 127.0.0.1 apenas local)
HOST=127.0.0.1

# ============================================
# BANCO DE DADOS
# ============================================

# String de conexão PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_banco
DATABASE_URL=postgresql://apoiotec:sua_senha_segura@localhost:5432/apoiotec

# Configurações individuais (caso precise)
PGHOST=localhost
PGPORT=5432
PGUSER=apoiotec
PGPASSWORD=sua_senha_segura
PGDATABASE=apoiotec

# ============================================
# INFORMAÇÕES DA EMPRESA
# ============================================

# Nome da empresa (aparece em PDFs e sistema)
COMPANY_NAME=Apoiotec Informática

# CNPJ da empresa
COMPANY_CNPJ=15.292.813.0001-70

# Endereço completo
COMPANY_ADDRESS=Rua Maestro Vila Lobos, N° 381, Abolição IV, Mossoró-RN

# Telefones (separados por hífen ou vírgula)
COMPANY_PHONE=84988288543 - 84988363828

# Emails (separados por hífen ou vírgula)
COMPANY_EMAIL=albano@hotmail.dk - marcelo@live.no

# ============================================
# SEGURANÇA
# ============================================

# Chave secreta para sessões (gere uma aleatória!)
# Você pode gerar uma usando: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=gere_uma_chave_aleatoria_aqui_com_pelo_menos_32_caracteres

# Tempo de expiração da sessão (em milissegundos)
# 24 horas = 86400000
# 7 dias = 604800000
SESSION_MAX_AGE=604800000

# ============================================
# PERSONALIZAÇÃO (Opcional)
# ============================================

# Tema padrão (light ou dark)
DEFAULT_THEME=light

# Tamanho de fonte do sistema (pixels: 22-40)
DEFAULT_FONT_SIZE=28

# Tamanho de fonte dos PDFs (pontos: 7-16)
DEFAULT_PDF_FONT_SIZE=10

# Família de fonte (inter, roboto, opensans, arial)
DEFAULT_FONT_FAMILY=inter

# Cor primária (formato hexadecimal)
DEFAULT_PRIMARY_COLOR=#2563eb

# Cor secundária (formato hexadecimal)
DEFAULT_SECONDARY_COLOR=#00ff41

# ============================================
# BACKUP (Opcional)
# ============================================

# Diretório onde os backups serão salvos
BACKUP_DIR=./backups

# Manter backups por quantos dias (0 = manter todos)
BACKUP_RETENTION_DAYS=30

# ============================================
# LOGS (Opcional)
# ============================================

# Nível de log (error, warn, info, debug)
LOG_LEVEL=info

# Diretório de logs
LOG_DIR=./logs

# ============================================
# DESENVOLVIMENTO (Apenas para dev)
# ============================================

# Replit específico - não altere se não estiver usando Replit
# REPLIT_DB_URL=
# REPL_ID=
# REPL_OWNER=
# REPL_SLUG=
